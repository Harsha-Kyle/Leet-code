class Solution {
    public boolean isSameAfterReversals(int num) {
        int c=0,n=num,m,s;
        for(int i=0;i<2;i++){
            s=0;
        while(n>0){
                m=n%10;
                s=s*10+m;
                n=n/10;
        }
        n=s;
        }
        if(n==num)
        return true;
        else
        return false;
    }
}
